page {
  background: #f7f7f7;
  color: #222;
  font-size: 18px;
  line-height: 1.4;
  overflow-x: hidden;
}

.container {
  padding: 20rpx 24rpx 120rpx;
}

/* For pages that have a fixed bottom action bar */
.container.with-fixed {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.brand {
  --red: #e53935;
  --red2: #ff4d4f;
  --card: #ffffff;
  --muted: #666;
  --border: rgba(0, 0, 0, 0.06);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.btn {
  height: 160rpx; /* >=80px */
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 600;
}

.btn-primary {
  background: #e53935;
  color: #fff;
}

.btn-plain {
  background: #fff;
  color: #222;
  border: 2rpx solid rgba(229, 57, 53, 0.22);
}

.hairline {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
}

.header {
  height: calc(var(--status-bar-height, 0px) + var(--nav-bar-height, 44px));
  padding: 0 20rpx;
  padding-top: var(--status-bar-height, 0px);
  padding-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

/* Fixed header for secondary pages */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 60;
}

.header-spacer {
  height: calc(var(--status-bar-height, 0px) + var(--nav-bar-height, 44px));
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back {
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(229, 57, 53, 0.08);
  color: #e53935;
  font-weight: 700;
}

.title {
  font-size: 20px;
  font-weight: 700;
}

.sub {
  font-size: 16px;
  color: #666;
}

.sub-inline {
  font-size: 14px;
  color: #666;
  font-weight: 600;
  margin-left: 12rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  overflow: hidden;
  flex: 0 0 auto;
  background: rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 900;
  color: rgba(0, 0, 0, 0.55);
  background: linear-gradient(180deg, rgba(229, 57, 53, 0.10), rgba(255, 255, 255, 0));
}

.name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.one-line {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.meta {
  flex: 0 0 auto;
  font-size: 13px;
  font-weight: 700;
  color: #e53935;
  background: rgba(229, 57, 53, 0.10);
  border: 1rpx solid rgba(229, 57, 53, 0.18);
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  line-height: 1;
}

.input {
  height: 96rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  font-size: 18px;
  box-sizing: border-box;
}

.field {
  margin-top: 18rpx;
}

.label {
  font-size: 16px;
  color: #666;
  margin-bottom: 10rpx;
}

.fixed-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(247, 247, 247, 0.92);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.fixed-bottom .btn {
  height: 104rpx;
  border-radius: 18rpx;
  font-size: 20px;
}

.fixed-actions {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
}

.fixed-actions .btn {
  flex: 1;
  flex-basis: 0;
  min-width: 0;
}

/* Fallback when flex gap is not supported */
.fixed-actions .btn + .btn {
  margin-left: 16rpx;
}
