textarea.input {
  box-sizing: border-box;
}

.photo-card {
  padding: 0;
  overflow: hidden;
  border-radius: 16rpx;
  position: relative;
  height: var(--photo-h, 360rpx);
  background: #fff;
}

.photo-img {
  width: 100%;
  display: block;
  height: 100%;
  background: #fff;
}

.photo-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: linear-gradient(180deg, rgba(229, 57, 53, 0.08), rgba(229, 57, 53, 0.03));
}

.photo-ph-title {
  color: #e53935;
  font-weight: 900;
  font-size: 18px;
}

.photo-ph-sub {
  margin-top: 8rpx;
  color: #666;
  font-size: 13px;
}

.photo-badge {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
}
