<view class="brand home" style="--status-bar-height: {{statusBarHeight}}px; --nav-bar-height: {{navBarHeight}}px;">
  <view class="home-hero">
    <view class="home-safe"></view>
    <view class="home-hero-inner">
      <view class="home-title">❤️ {{'红娘工作台'}}</view>
    </view>
  </view>

  <view class="container home-container">
    <view class="grid">
      <view class="tile tile-male" bindtap="goMale">
        <view class="tile-top">
          <view class="tile-ico">👨</view>
          <view class="tile-top-right">
            <view class="tile-count">{{stats.male}} 人</view>
            <view class="tile-arrow">›</view>
          </view>
        </view>
        <view class="tile-title">男客户</view>
        <view class="tile-sub">录入 / 搜索 / 查看</view>
      </view>

      <view class="tile tile-female" bindtap="goFemale">
        <view class="tile-top">
          <view class="tile-ico">👩</view>
          <view class="tile-top-right">
            <view class="tile-count">{{stats.female}} 人</view>
            <view class="tile-arrow">›</view>
          </view>
        </view>
        <view class="tile-title">女客户</view>
        <view class="tile-sub">录入 / 搜索 / 查看</view>
      </view>

      <block wx:if="{{canShowShowcase}}">
        <view class="tile tile-showcase" bindtap="goShowcase">
          <view class="tile-top">
            <view class="tile-ico">📢</view>
            <view class="tile-arrow">›</view>
          </view>
          <view class="tile-title">展示页</view>
          <view class="tile-sub">对外展示 / 分享</view>
        </view>
      </block>
    </view>
  </view>
</view>
