
.home-hero {
	background: radial-gradient(1200rpx 600rpx at 10% 20%, rgba(255, 77, 79, 0.18), rgba(255, 77, 79, 0)),
		linear-gradient(180deg, rgba(229, 57, 53, 0.12), rgba(229, 57, 53, 0));
}

.home-safe {
	height: calc(var(--status-bar-height, 0px) + var(--nav-bar-height, 44px));
}

.home-hero-inner {
	padding: 12rpx 24rpx 18rpx;
}

.home-title {
	font-size: 22px;
	font-weight: 900;
	color: #e53935;
	letter-spacing: 0.2px;
}

.home-container {
	padding-top: 8rpx;
}

.grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 18rpx;
}

.tile {
	background: #fff;
	border-radius: 20rpx;
	border: 1rpx solid rgba(0, 0, 0, 0.05);
	box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.05);
	padding: 26rpx 22rpx;
	min-height: 240rpx;
	box-sizing: border-box;
}

.tile-top {
	display: flex;
	align-items: center;
	justify-content: space-between;
}

.tile-top-right {
	display: flex;
	align-items: center;
	gap: 10rpx;
}

.tile-count {
	font-size: 12px;
	font-weight: 800;
	color: rgba(0, 0, 0, 0.6);
	background: rgba(255, 255, 255, 0.75);
	border: 1rpx solid rgba(0, 0, 0, 0.06);
	padding: 6rpx 10rpx;
	border-radius: 999rpx;
}

.tile-ico {
	width: 88rpx;
	height: 88rpx;
	border-radius: 20rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 26px;
	background: rgba(229, 57, 53, 0.08);
}

.tile-arrow {
	color: rgba(0, 0, 0, 0.35);
	font-size: 22px;
	font-weight: 800;
}

.tile-title {
	margin-top: 18rpx;
	font-size: 20px;
	font-weight: 900;
	color: #111;
}

.tile-sub {
	margin-top: 10rpx;
	font-size: 14px;
	color: #666;
}

.tile-male {
	background: linear-gradient(180deg, rgba(33, 150, 243, 0.10), rgba(255, 255, 255, 0));
}

.tile-male .tile-ico {
	background: rgba(33, 150, 243, 0.12);
}

.tile-female {
	background: linear-gradient(180deg, rgba(233, 30, 99, 0.10), rgba(255, 255, 255, 0));
}

.tile-female .tile-ico {
	background: rgba(233, 30, 99, 0.12);
}

.tile-match {
	background: linear-gradient(135deg, rgba(229, 57, 53, 0.16), rgba(255, 77, 79, 0.06));
	border: 1rpx solid rgba(229, 57, 53, 0.18);
}

.tile-match .tile-ico {
	background: rgba(229, 57, 53, 0.14);
}

.tile-showcase {
	background: linear-gradient(180deg, rgba(255, 193, 7, 0.12), rgba(255, 255, 255, 0));
}

.tile-showcase .tile-ico {
	background: rgba(255, 193, 7, 0.14);
}

.action {
	background: #fff;
	border-radius: 18rpx;
	border: 1rpx solid rgba(0, 0, 0, 0.05);
	box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.05);
	padding: 22rpx 20rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
}

.action-left {
	display: flex;
	align-items: center;
	gap: 16rpx;
}

.action-ico {
	width: 72rpx;
	height: 72rpx;
	border-radius: 18rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	background: rgba(229, 57, 53, 0.08);
	font-size: 22px;
}

.action-title {
	font-size: 18px;
	font-weight: 900;
	color: #111;
}

.action-sub {
	margin-top: 6rpx;
	font-size: 14px;
	color: #666;
}

.action-arrow {
	color: rgba(0, 0, 0, 0.35);
	font-size: 22px;
	font-weight: 700;
}

.action-primary {
	background: linear-gradient(90deg, #e53935, #ff4d4f);
	border: 0;
}

.action-primary .action-title,
.action-primary .action-sub,
.action-primary .action-arrow {
	color: #fff;
}

.action-primary .action-ico {
	background: rgba(255, 255, 255, 0.2);
}
